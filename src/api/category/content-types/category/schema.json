{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Categories for portfolio items and case studies"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "portfolio_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::portfolio-item.portfolio-item",
      "mappedBy": "categories"
    },
    "case_study_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::case-study-item.case-study-item",
      "mappedBy": "categories"
    }
  }
}
